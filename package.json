{
  "name": "@djomo05/wysiwyg-editor",
  "version": "1.0.0",
  "description": "A fully-featured, modular WYSIWYG editor built with TypeScript. Supports image, video, links, tables, source editing, preview mode, and fullscreen. Docker-ready.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/umd/wysiwyg-editor.min.js",
  "style": "dist/styles/editor.css",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./styles": "./dist/styles/editor.css"
  },
"scripts": {
  "build": "npm run clean && npm run build:rollup && npm run build:types && npm run build:css",
  "build:rollup": "rollup -c rollup.config.mjs",
  "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
  "build:css": "shx mkdir -p dist/styles && shx cp src/styles/editor.css dist/styles/editor.css",
  "clean": "rimraf dist",
  "dev": "node src/demo/server.js",
  "test": "jest --config jest.config.js",
  "lint": "eslint src/**/*.ts",
  "prepublishOnly": "npm run build",
  "docker:build": "docker build -t wysiwyg-editor .",
  "docker:run": "docker-compose up",
  "docker:stop": "docker-compose down"
},
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "typescript",
    "docker",
    "modular",
    "fullscreen",
    "source-editor",
    "preview"
  ],
  "author": "Djomo05",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.6",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}